# Docker Compose environment template
# Copy to .env before running:  cp .env.example .env
#
# Used by docker-compose.yml for variable substitution and service env_file.
# NEXT_PUBLIC_* values are also passed as frontend build args (baked at build time).

# =============================================================================
# Core URLs (adjust for production)
# =============================================================================
# Public API URL the browser calls (frontend build arg + backend CORS context)
NEXT_PUBLIC_BASE_URL=http://localhost:4000
# Public app URL for email links and OpenRouter HTTP-Referer
APP_URL=http://localhost:3000

# Landing page GitHub link (frontend build arg)
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/eboom

# Host port mappings
FRONTEND_PORT=3000
BACKEND_PORT=4000

# =============================================================================
# PostgreSQL (docker-compose postgres service)
# =============================================================================
POSTGRES_USER=eboom
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=eboom

# =============================================================================
# Auth (backend)
# =============================================================================
JWT_SECRET=change-me-in-production-minimum-32-characters
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Set to 1 to skip email verification on signup (dev/demo only)
SKIP_EMAIL_VERIFICATION=0

# Dev/testing only — bypass auth with a fixed user id (never in production)
# TEST_USER_ID=1

# =============================================================================
# SMTP (backend — signup, password reset, notifications)
# =============================================================================
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=noreply@example.com

# Overdue notification emails (backend job)
# NOTIFICATION_EMAIL_ENABLED=1
# NOTIFICATION_EMAIL_INTERVAL_MS=3600000

# =============================================================================
# AI insights & chat (backend — OpenAI or OpenRouter)
# =============================================================================
# Option A — OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Option B — OpenRouter (https://openrouter.ai/settings/keys)
# OPENROUTER_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemini-2.0-flash-exp:free

# Generic aliases (either provider)
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

# =============================================================================
# Optional: seed demo data after stack is up
# =============================================================================
# docker compose exec backend node dist/db/seed/seed.js
