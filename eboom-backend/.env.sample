NEXT_PUBLIC_BASE_URL=https://127.0.0.1:<port>
DATABASE_URL=postgres://postgres:<password>@<host>:<port>/<db-name>
APP_URL=http://127.0.0.1:<port>

# JWT authentication
JWT_SECRET=<random-secret-at-least-32-chars>
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# SMTP configuration for email verification and password reset
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=example@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=example@gmail.com

# Overdue notification emails (runs on a schedule and when notifications are fetched)
# Set NOTIFICATION_EMAIL_ENABLED=0 to disable
# NOTIFICATION_EMAIL_INTERVAL_MS=3600000

# ============================================================================
# TESTING BYPASS - Authentication
# ============================================================================
# Uncomment and set to a valid user ID to bypass authentication for testing
# WARNING: Remove or comment out in production!
# Example: TEST_USER_ID=1
# TEST_USER_ID=

# ============================================================================
# DEVELOPMENT - Skip email verification
# ============================================================================
# Set to 1 to auto-verify new signups and allow login without email confirmation
# WARNING: Never enable in production!
# SKIP_EMAIL_VERIFICATION=1